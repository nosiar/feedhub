{
  "name": "feedhub",
  "version": "0.1.0",
  "description": "Unified feed reader for Gmail, KakaoTalk, Slack, and RSS",
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "dev:web": "cd web && npx vite",
    "build": "tsc && cd web && npm run build",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@slack/web-api": "^7.15.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.8.4",
    "googleapis": "^171.4.0",
    "mongodb": "^7.1.1",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
